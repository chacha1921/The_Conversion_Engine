# ── Kill-switch ──────────────────────────────────────────────────────
# DELIBERATELY left unset. Default routes all outbound to the staff sink.
# Set to "true" ONLY when you intend to send live outbound.
# TENACIOUS_OUTBOUND_ENABLED=true

# ── LLM ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# ── Email (Resend or MailerSend) ─────────────────────────────────────
RESEND_API_KEY=
# or
MAILERSEND_API_KEY=
EMAIL_FROM=

# ── SMS (Africa's Talking) ───────────────────────────────────────────
AT_USERNAME=
AT_API_KEY=
AT_SHORTCODE=

# ── CRM (HubSpot) ────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=

# ── Calendar (Cal.com) ───────────────────────────────────────────────
CALCOM_API_KEY=
CALCOM_BASE_URL=http://localhost:3000

# ── Observability (Langfuse) ─────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Staff sink (for challenge week routing) ───────────────────────────
STAFF_SINK_URL=

# ── Shared Voice Rig (bonus tier only) ───────────────────────────────
VOICE_RIG_WEBHOOK_URL=
VOICE_RIG_KEYWORD_PREFIX=
